{
  "name": "my-qwik-empty-starter",
  "description": "Blank project with routing included",
  "engines": {
    "node": "^18.17.0 || ^20.3.0 || >=21.0.0"
  },
  "engines-annotation": "Mostly required by sharp which needs a Node-API v9 compatible runtime",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "qwik build",
    "build-storybook": "storybook build",
    "build.client": "vite build",
    "build.preview": "vite build --ssr src/entry.preview.tsx",
    "build.server": "qwik check-client src dist && vite build -c adapters/static/vite.config.ts",
    "build.types": "tsc --incremental --noEmit",
    "deploy": "./scripts/deploy-s3.sh",
    "deploy.dev": "VITE_STAGE_NAME=dev pnpm run deploy",
    "deploy.stg": "VITE_STAGE_NAME=stg pnpm run deploy",
    "deploy.prod": "VITE_STAGE_NAME=prod pnpm run deploy",
    "dev": "VITE_STAGE_NAME=dev vite --mode ssr",
    "dev.debug": "node --inspect-brk ./node_modules/vite/bin/vite.js --mode ssr --force",
    "fmt": "prettier --write ./src",
    "fmt.check": "prettier --check ./src",
    "generate:openapi": "openapi-typescript http://localhost:9000/lambda-url/http-api/api-gateway/api/v1/openapi.json -o src/openapi/schema.ts",
    "lint": "eslint \"src/**/*.ts*\"",
    "postdeploy": "./scripts/invalidate.sh",
    "predeploy": "pnpm run build",
    "preview": "qwik build preview && vite preview --open",
    "start": "vite --open --mode ssr",
    "storybook": "storybook dev -p 11071 --no-open",
    "qwik": "qwik",
    "check": "pnpm run lint && pnpm run build.types && pnpm run fmt.check"
  },
  "devDependencies": {
    "@elmethis/core": "^0.13.0",
    "@elmethis/qwik": "^1.0.0-alpha.29",
    "@eslint/js": "^9",
    "@formkit/auto-animate": "^0.9.0",
    "@js-temporal/polyfill": "^0.5.1",
    "@mdi/js": "^7.4.47",
    "@qwik.dev/core": "^2.0.0-beta.36",
    "@qwik.dev/router": "^2.0.0-beta.36",
    "@storybook/addon-docs": "^10.4.0",
    "@types/node": "20.19.0",
    "aws-amplify": "^6.16.2",
    "es-toolkit": "^1.46.1",
    "eslint": "9.32.0",
    "eslint-plugin-qwik": "^2.0.0-beta.36",
    "fuse.js": "^7.1.0",
    "globals": "16.4.0",
    "openapi-fetch": "^0.17.0",
    "openapi-typescript": "^7.13.0",
    "pkce-challenge": "^5.0.1",
    "prettier": "3.6.2",
    "storybook": "^10.4.0",
    "storybook-framework-qwik": "0.6.2--canary.95.25602496384.0",
    "typescript": "5.8",
    "typescript-eslint": "8.38.0",
    "typescript-plugin-css-modules": "latest",
    "undici": "*",
    "vite": "7.3.5",
    "vite-tsconfig-paths": "^4.2.1"
  }
}