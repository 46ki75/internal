{
  "name": "my-qwik-empty-starter",
  "description": "Blank project with routing included",
  "engines": {
    "node": "^18.17.0 || ^20.3.0 || >=21.0.0"
  },
  "engines-annotation": "Mostly required by sharp which needs a Node-API v9 compatible runtime",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "qwik build",
    "build-storybook": "storybook build",
    "build.client": "vite build",
    "build.preview": "vite build --ssr src/entry.preview.tsx",
    "build.server": "qwik check-client src dist && vite build -c adapters/static/vite.config.ts",
    "build.types": "tsc --incremental --noEmit",
    "deploy": "./scripts/deploy-s3.sh",
    "deploy.dev": "VITE_STAGE_NAME=dev pnpm run deploy",
    "deploy.stg": "VITE_STAGE_NAME=stg pnpm run deploy",
    "deploy.prod": "VITE_STAGE_NAME=prod pnpm run deploy",
    "dev": "VITE_STAGE_NAME=dev vite --mode ssr",
    "dev.debug": "node --inspect-brk ./node_modules/vite/bin/vite.js --mode ssr --force",
    "fmt": "prettier --write .",
    "fmt.check": "prettier --check .",
    "generate:openapi": "openapi-typescript http://localhost:9000/lambda-url/internal-graphql/api-gateway/api/v1/openapi.json -o src/openapi/schema.ts",
    "lint": "eslint \"src/**/*.ts*\"",
    "postdeploy": "./scripts/invalidate.sh",
    "predeploy": "pnpm run build",
    "preview": "qwik build preview && vite preview --open",
    "start": "vite --open --mode ssr",
    "storybook": "storybook dev -p 11071",
    "qwik": "qwik"
  },
  "devDependencies": {
    "@builder.io/qwik": "^1.19.2",
    "@builder.io/qwik-city": "^1.19.2",
    "@elmethis/qwik": "^0.0.70",
    "@eslint/js": "^9",
    "@mdi/js": "^7.4.47",
    "@storybook/addon-docs": "^10.3.5",
    "@types/node": "20.19.0",
    "aws-amplify": "^6.16.2",
    "eslint": "9.32.0",
    "eslint-plugin-qwik": "^1.19.2",
    "globals": "16.4.0",
    "openapi-fetch": "^0.17.0",
    "openapi-typescript": "^7.13.0",
    "prettier": "3.6.2",
    "qwik-transition": "^0.0.7",
    "storybook": "^10.3.5",
    "storybook-framework-qwik": "0.6.1",
    "typescript": "5.4.5",
    "typescript-eslint": "8.38.0",
    "typescript-plugin-css-modules": "latest",
    "undici": "*",
    "vite": "7.3.1",
    "vite-tsconfig-paths": "^4.2.1"
  }
}