{
  "name": "@46ki75/internal-web",
  "description": "SolidStart frontend for internal.46ki75.com",
  "engines": {
    "node": ">=22.0.0"
  },
  "engines-annotation": "Mostly required by sharp which needs a Node-API v9 compatible runtime",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vinxi build",
    "build-storybook": "storybook build",
    "build.types": "tsc --incremental --noEmit",
    "deploy": "./scripts/deploy-s3.sh",
    "deploy.dev": "VITE_STAGE_NAME=dev pnpm run deploy",
    "deploy.stg": "VITE_STAGE_NAME=stg pnpm run deploy",
    "deploy.prod": "VITE_STAGE_NAME=prod pnpm run deploy",
    "dev": "VITE_STAGE_NAME=dev vinxi dev",
    "dev.debug": "VITE_STAGE_NAME=dev node --inspect-brk ./node_modules/vinxi/bin/cli.mjs dev",
    "fmt": "prettier --write ./src",
    "fmt.check": "prettier --check ./src",
    "generate:openapi": "openapi-typescript http://localhost:9000/lambda-url/http-api/api-gateway/api/v1/openapi.json -o src/openapi/schema.ts",
    "lint": "eslint \"{src,.storybook}/**/*.{ts,tsx}\"",
    "postdeploy": "./scripts/invalidate.sh",
    "predeploy": "pnpm run build",
    "preview": "vinxi start",
    "start": "vinxi dev --open",
    "storybook": "storybook dev -p 11071 --no-open",
    "test": "vitest run",
    "check": "pnpm run lint && pnpm run build.types && pnpm run test && pnpm run fmt.check"
  },
  "dependencies": {
    "@ag-ui/client": "0.0.57",
    "@elmethis/core": "^0.20.0",
    "@elmethis/solid": "^0.1.1",
    "@formkit/auto-animate": "^0.10.0",
    "@js-temporal/polyfill": "^0.5.1",
    "@mdi/js": "^7.4.47",
    "@solidjs/meta": "^0.29.4",
    "@solidjs/router": "^0.16.2",
    "@solidjs/start": "^1.3.2",
    "aws-amplify": "^6.16.2",
    "es-toolkit": "^1.46.1",
    "fuse.js": "^7.1.0",
    "openapi-fetch": "^0.17.0",
    "solid-js": "^1.9.14",
    "vinxi": "^0.5.11"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@solidjs/testing-library": "^0.8.10",
    "@storybook/addon-a11y": "^10.5.2",
    "@storybook/addon-docs": "^10.5.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "20.19.0",
    "eslint": "9.32.0",
    "eslint-plugin-solid": "^0.14.5",
    "globals": "16.4.0",
    "openapi-typescript": "^7.13.0",
    "prettier": "3.6.2",
    "storybook": "^10.5.2",
    "storybook-solidjs-vite": "^10.5.2",
    "typescript": "5.8",
    "typescript-eslint": "8.38.0",
    "typescript-plugin-css-modules": "latest",
    "vite": "7.3.5",
    "vite-plugin-solid": "^2.11.10",
    "vitest": "^4.1.10",
    "happy-dom": "^20.11.0"
  }
}
